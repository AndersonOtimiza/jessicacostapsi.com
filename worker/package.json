{
  "name": "jessicacostapsi-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Worker da Jessica Costa Psi para sistema de cursos (auth, vitrine, player Stream, certificado, webhook Otimiza).",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "d1:init": "wrangler d1 execute jessicacostapsi-cursos --file=migrations/0001_init.sql",
    "d1:seed": "wrangler d1 execute jessicacostapsi-cursos --file=migrations/0002_seed.sql",
    "d1:init:remote": "wrangler d1 execute jessicacostapsi-cursos --remote --file=migrations/0001_init.sql",
    "d1:seed:remote": "wrangler d1 execute jessicacostapsi-cursos --remote --file=migrations/0002_seed.sql"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "undici": "^6.24.0"
  }
}
